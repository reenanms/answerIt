{
  "manifest_version": 3,
  "name": "AnswerIt",
  "version": "1.0.0",
  "description": "Automatically identifies questions on a webpage and highlights the correct answer using AI.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://*.mheducation.com/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "AnswerIt"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.mheducation.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "style.css"
      ]
    }
  ]
}